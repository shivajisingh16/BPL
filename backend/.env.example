# Server
PORT=3001
NODE_ENV=development

# Persistence: path to the JSON data file the store reads/writes.
# Optional — defaults to backend/data/bpl-db.json. Relative paths resolve
# from the backend folder. Delete the file (or run `npm run seed`) to reset.
# DATA_FILE=data/bpl-db.json

# Comma-separated list of allowed CORS origins (frontend dev server, etc.)
CORS_ORIGIN=http://localhost:5173

# Auth
# Any email matching this domain is allowed to log in with the shared password.
AUTH_ALLOWED_DOMAIN=bot.com
AUTH_PASSWORD=secret
# Secret used to sign session tokens. Change this in production.
AUTH_TOKEN_SECRET=change-me-in-production
# Token lifetime in hours
AUTH_TOKEN_TTL_HOURS=12
