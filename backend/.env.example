# Server
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed CORS origins (frontend dev server, etc.)
CORS_ORIGIN=http://localhost:5173

# Persistence — MongoDB Atlas
# Paste your cluster connection string. Get it from the Atlas dashboard:
#   Database → Connect → Drivers → Node.js.
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Database name created/used inside the cluster.
MONGODB_DB=bpl

# Auth
# Domain used to derive each player's admin email (e.g. shivaji@bot.com).
AUTH_ALLOWED_DOMAIN=bot.com
# Shared password seeded for every player-derived admin account.
AUTH_PASSWORD=secret
# Dedicated super-admin account (identical powers, nothing extra).
ADMIN_EMAIL=admin@bot.com
ADMIN_PASSWORD=admin
# Secret used to sign session tokens. Change this in production.
AUTH_TOKEN_SECRET=change-me-in-production
# Token lifetime in hours
AUTH_TOKEN_TTL_HOURS=12
